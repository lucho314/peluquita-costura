---
import Base from '../layouts/Base.astro'
import ContactForm from '../components/ContactForm.astro'
---

<Base title="Contacto - Peluquita Costuras" description="Contactanos para consultas o encargos personalizados">
  <!-- Header -->
  <section class="bg-gradient-to-br from-[var(--color-secondary)] to-[var(--color-tertiary)] py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-serif font-bold text-white mb-4">
        Contacto
      </h1>
      <p class="text-xl text-white/90 max-w-2xl mx-auto">
        ¿Tenés alguna consulta o querés hacer un encargo? Escribinos
      </p>
    </div>
  </section>

  <!-- Contenido de contacto -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Formulario -->
        <div>
          <h2 class="text-2xl font-serif font-bold text-gray-900 mb-6">
            Envianos un mensaje
          </h2>
          <ContactForm />
        </div>

        <!-- Información de contacto -->
        <div>
          <h2 class="text-2xl font-serif font-bold text-gray-900 mb-6">
            Información de contacto
          </h2>

          <div class="space-y-6">
            <!-- Email -->
            <div class="flex items-start">
              <div class="flex-shrink-0">
                <svg class="h-6 w-6" style="color: var(--color-primary)" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div class="ml-4">
                <p class="text-sm font-medium text-gray-900">Email</p>
                <a href="mailto:contacto@peluquitacosturas.com" class="text-sm text-gray-600 hover:text-[var(--color-primary)] transition-colors">
                  contacto@peluquitacosturas.com
                </a>
              </div>
            </div>

            <!-- Teléfono -->
            <div class="flex items-start">
              <div class="flex-shrink-0">
                <svg class="h-6 w-6" style="color: var(--color-primary)" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div class="ml-4">
                <p class="text-sm font-medium text-gray-900">Teléfono</p>
                <a href="tel:+5491112345678" class="text-sm text-gray-600 hover:text-[var(--color-primary)] transition-colors">
                  (11) 1234-5678
                </a>
              </div>
            </div>

            <!-- Ubicación -->
            <div class="flex items-start">
              <div class="flex-shrink-0">
                <svg class="h-6 w-6" style="color: var(--color-primary)" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div class="ml-4">
                <p class="text-sm font-medium text-gray-900">Ubicación</p>
                <p class="text-sm text-gray-600">
                  Buenos Aires, Argentina
                </p>
              </div>
            </div>

            <!-- Redes sociales -->
            <div class="pt-6 border-t border-gray-200">
              <p class="text-sm font-medium text-gray-900 mb-4">Seguinos en redes</p>
              <div class="flex space-x-4">
                <a
                  href="#"
                  class="text-gray-400 hover:text-[var(--color-primary)] transition-colors"
                  aria-label="Instagram"
                >
                  <svg class="h-8 w-8" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                  </svg>
                </a>

                <a
                  href="#"
                  class="text-gray-400 hover:text-[var(--color-primary)] transition-colors"
                  aria-label="WhatsApp"
                >
                  <svg class="h-8 w-8" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                  </svg>
                </a>
              </div>
            </div>
          </div>

          <!-- Card adicional -->
          <div class="mt-8 p-6 bg-gray-50 rounded-lg border border-gray-200">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">
              Horario de atención
            </h3>
            <p class="text-sm text-gray-600">
              Lunes a viernes: 9:00 - 18:00 hs<br>
              Sábados: 10:00 - 14:00 hs
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
