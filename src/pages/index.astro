---
import Base from '../layouts/Base.astro'
import Hero from '../components/Hero.astro'
import ProductCard from '../components/ProductCard.astro'
import { getSupabase } from '../lib/supabase'

// Obtener productos destacados (últimos 6 con stock)
const { data: productos } = await getSupabase()
  .from('productos')
  .select(`
    id,
    nombre,
    precio_venta,
    stock,
    producto_imagenes (
      url,
      orden
    )
  `)
  .gt('stock', 0)
  .order('created_at', { ascending: false })
  .limit(6)

const productosConImagenes = productos?.map(producto => ({
  ...producto,
  imagen: producto.producto_imagenes?.[0]?.url
})) || []

const homeJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': new URL('/', Astro.site ?? 'https://peluquita-costura.luciano-zapata314.workers.dev').toString(),
  url: new URL('/', Astro.site ?? 'https://peluquita-costura.luciano-zapata314.workers.dev').toString(),
  name: 'Peluquita Costuras | Costura artesanal a medida',
  description: 'Costura artesanal a medida en Paraná, Entre Ríos. Prendas, accesorios textiles, cortinas, almohadones y confecciones personalizadas con terminaciones cuidadas.',
  inLanguage: 'es-AR',
  isPartOf: {
    '@id': new URL('/#website', Astro.site ?? 'https://peluquita-costura.luciano-zapata314.workers.dev').toString()
  }
}
---

<Base
  title="Peluquita Costuras | Costura artesanal a medida"
  description="Costura artesanal a medida en Paraná, Entre Ríos. Prendas, accesorios textiles, cortinas, almohadones y confecciones personalizadas con terminaciones cuidadas."
  jsonLd={homeJsonLd}
>
  <Hero
    title="Costura artesanal hecha a medida"
    subtitle="Confecciones únicas con dedicación y calidad"
  />

  <!-- Productos destacados -->
  <section class="mx-auto max-w-7xl px-6 py-24 sm:px-8">
    <div class="mb-16 flex flex-col items-start justify-between gap-4 md:flex-row md:items-end">
      <div>
        <h2 class="font-headline text-4xl text-[var(--color-primary)]">
          Nuestras Creaciones
        </h2>
        <div class="mt-4 h-1 w-24 bg-[var(--color-secondary-container)]"></div>
      </div>
      <p class="font-body max-w-xs text-[var(--color-on-surface-variant)] italic">
        Piezas exclusivas que cuentan una historia en cada puntada.
      </p>
    </div>

      {productosConImagenes.length > 0 ? (
        <div class="featured-grid mb-10 grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
          {productosConImagenes.map((producto) => (
            <ProductCard
              id={producto.id}
              nombre={producto.nombre}
              precio={producto.precio_venta}
              imagen={producto.imagen}
              stock={producto.stock}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <p class="text-lg text-[var(--color-on-surface-variant)]">No hay productos disponibles en este momento.</p>
        </div>
      )}

      <div class="text-center">
        <a
          href="/productos"
          class="font-label inline-flex items-center rounded-full border border-[var(--color-primary)] px-8 py-3 text-sm font-bold uppercase tracking-widest text-[var(--color-primary)] transition-all hover:-translate-y-1 hover:bg-[var(--color-primary)] hover:text-white hover:shadow-xl"
        >
          Ver catálogo completo
        </a>
      </div>
  </section>

  <!-- Sobre nosotros -->
  <section class="overflow-hidden bg-[var(--color-secondary-container)]/20 px-6 py-24 sm:px-8">
    <div class="mx-auto flex max-w-7xl flex-col items-center gap-16 md:flex-row">
      <div class="relative w-full md:w-1/2">
        <div class="absolute -left-4 -top-4 h-full w-full rounded-xl border border-[var(--color-secondary)]/30"></div>
        <img
          src="/hero-costura.webp"
          alt="Taller de costura artesanal con materiales y herramientas de confección"
          width="1551"
          height="1014"
          loading="lazy"
          decoding="async"
          class="relative z-10 h-[500px] w-full rounded-xl object-cover shadow-lg"
        />
      </div>
      <div class="w-full md:w-1/2">
        <span class="font-label mb-4 block text-xs font-bold uppercase tracking-widest text-[var(--color-secondary)]">
          Nuestra Historia
        </span>
        <h2 class="font-headline mb-8 text-4xl text-[var(--color-primary)]">
          El arte de lo hecho a mano
        </h2>
        <p class="font-body mb-6 text-lg leading-relaxed text-[var(--color-on-surface-variant)]">
          En Peluquita Costuras nos dedicamos a la confección de prendas y accesorios textiles únicos y personalizados.
          Cada pieza es trabajada con dedicación y atención al detalle, utilizando materiales de primera calidad.
        </p>
        <p class="font-body mb-8 text-lg leading-relaxed text-[var(--color-on-surface-variant)] italic">
          Desde vestidos a medida hasta almohadones bordados, cortinas artesanales y bolsos de tela,
          cada confección refleja nuestro compromiso con la excelencia y el diseño personalizado.
        </p>
        <div class="flex items-center gap-8 border-t border-[var(--color-outline-variant)]/30 pt-8">
          <div>
            <p class="font-headline text-2xl text-[var(--color-primary)]">25+</p>
            <p class="font-label text-xs uppercase tracking-tight text-[var(--color-on-surface-variant)]">Años de tradición</p>
          </div>
          <div class="h-10 w-px bg-[var(--color-outline-variant)]/30"></div>
          <div>
            <p class="font-headline text-2xl text-[var(--color-primary)]">100%</p>
            <p class="font-label text-xs uppercase tracking-tight text-[var(--color-on-surface-variant)]">Hecho a mano</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="relative flex flex-col items-center overflow-hidden px-6 py-24 text-center sm:px-8">
    <div class="absolute inset-0 z-0 bg-[var(--color-secondary-container)]/30"></div>
    <div class="relative z-10 max-w-3xl">
      <h2 class="font-headline mb-6 text-4xl text-[var(--color-primary)] md:text-5xl">
        ¿Necesitás algo a medida?
      </h2>
      <p class="font-body mb-10 text-xl leading-relaxed text-[var(--color-on-surface-variant)]">
        Contactanos y te ayudamos a crear la confección perfecta para vos
      </p>
      <a
        href="/contacto"
        class="font-label inline-flex rounded-full bg-[var(--color-primary)] px-12 py-4 font-bold uppercase tracking-widest text-white shadow-md transition-all hover:-translate-y-1 hover:bg-[var(--color-secondary)] hover:shadow-xl"
      >
        Consultar
      </a>
    </div>
  </section>
</Base>

<style>
  .featured-grid > :global(article:nth-child(even)) {
    padding-top: 3rem;
  }

  @media (max-width: 767px) {
    .featured-grid > :global(article:nth-child(even)) {
      padding-top: 0;
    }
  }
</style>
