---
import Base from '../../layouts/Base.astro'
import ProductCard from '../../components/ProductCard.astro'
import { getSupabase } from '../../lib/supabase'

// Obtener todos los productos con stock
const { data: productos } = await getSupabase()
  .from('productos')
  .select(`
    id,
    nombre,
    precio_venta,
    stock,
    producto_imagenes (
      url,
      orden
    )
  `)
  .gt('stock', 0)
  .order('created_at', { ascending: false })

const productosConImagenes = productos?.map(producto => ({
  ...producto,
  imagen: producto.producto_imagenes?.[0]?.url
})) || []

const siteUrl = Astro.site ?? 'https://peluquita-costura.luciano-zapata314.workers.dev'
const catalogUrl = new URL('/productos', siteUrl).toString()
const catalogJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': catalogUrl,
    url: catalogUrl,
    name: 'Catálogo de confecciones artesanales',
    description: 'Prendas, accesorios textiles y confecciones artesanales disponibles en Paraná, Entre Ríos.',
    inLanguage: 'es-AR',
    isPartOf: {
      '@id': new URL('/#website', siteUrl).toString()
    }
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Productos disponibles de Peluquita Costuras',
    itemListElement: productosConImagenes.map((producto, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: new URL(`/productos/${producto.id}`, siteUrl).toString(),
      name: producto.nombre
    }))
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Inicio',
        item: new URL('/', siteUrl).toString()
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Catálogo',
        item: catalogUrl
      }
    ]
  }
]
---

<Base title="Catálogo de confecciones artesanales | Peluquita Costuras" description="Explorá prendas, accesorios textiles y confecciones artesanales disponibles. Piezas hechas a medida con materiales de calidad en Paraná, Entre Ríos." jsonLd={catalogJsonLd}>
  <!-- Header -->
  <section class="bg-[var(--color-secondary-container)]/30 px-6 pb-16 pt-32 sm:px-8">
    <div class="mx-auto max-w-7xl text-center">
      <span class="font-label mb-4 block text-xs font-bold uppercase tracking-[0.24em] text-[var(--color-secondary)]">Atelier artesanal</span>
      <h1 class="font-headline mb-4 text-4xl text-[var(--color-primary)] sm:text-5xl">
        Nuestro Catálogo
      </h1>
      <p class="mx-auto max-w-2xl text-xl text-[var(--color-on-surface-variant)]">
        Prendas y confecciones hechas a medida
      </p>
    </div>
  </section>

  <!-- Catálogo de productos -->
  <section class="bg-[var(--color-background)] px-6 py-20 sm:px-8">
    <div class="mx-auto max-w-7xl">
      {productosConImagenes.length > 0 ? (
        <>
          <div class="mb-10 flex flex-col items-start justify-between gap-4 border-b border-[var(--color-outline-variant)]/40 pb-6 sm:flex-row sm:items-center">
            <p class="font-label text-sm uppercase tracking-[0.18em] text-[var(--color-on-surface-variant)]">
              Mostrando {productosConImagenes.length} {productosConImagenes.length === 1 ? 'producto' : 'productos'}
            </p>
            <span class="font-script text-3xl text-[var(--color-primary)]">Hecho a mano</span>
          </div>

          <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
            {productosConImagenes.map((producto) => (
              <ProductCard
                id={producto.id}
                nombre={producto.nombre}
                precio={producto.precio_venta}
                imagen={producto.imagen}
                stock={producto.stock}
              />
            ))}
          </div>
        </>
      ) : (
        <div class="mx-auto max-w-2xl rounded-2xl border border-[var(--color-outline-variant)]/60 bg-white/45 px-8 py-16 text-center shadow-[0_18px_60px_rgba(31,27,19,0.08)] backdrop-blur-sm">
          <svg class="mx-auto mb-6 h-20 w-20 text-[var(--color-secondary)]/60" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
          </svg>
          <h3 class="font-headline mb-3 text-2xl text-[var(--color-primary)]">
            No hay productos disponibles
          </h3>
          <p class="font-body mx-auto mb-8 max-w-md text-[var(--color-on-surface-variant)]">
            En este momento no tenemos productos en stock. Volvé pronto o contactanos para consultar por encargos.
          </p>
          <a
            href="/contacto"
            class="font-label inline-flex items-center rounded-full bg-[var(--color-primary)] px-10 py-4 text-sm font-bold uppercase tracking-widest text-white shadow-md transition-all hover:-translate-y-1 hover:bg-[var(--color-secondary)] hover:shadow-xl"
          >
            Contactar
          </a>
        </div>
      )}
    </div>
  </section>
</Base>
