---
import Base from '../../layouts/Base.astro'
import ProductGallery from '../../components/ProductGallery.astro'
import ContactForm from '../../components/ContactForm.astro'
import { getSupabase } from '../../lib/supabase'

const { id } = Astro.params

const { data: producto } = await getSupabase()
  .from('productos')
  .select(`
    id,
    nombre,
    precio_venta,
    stock,
    producto_imagenes (
      id,
      url,
      orden,
      alt
    )
  `)
  .eq('id', id)
  .single()

if (!producto) {
  return Astro.redirect('/productos')
}

const imagenes = producto.producto_imagenes || []
const imagenesSorted = [...imagenes].sort((a, b) => (a.orden || 0) - (b.orden || 0))

const precioFormateado = new Intl.NumberFormat('es-AR', {
  style: 'currency',
  currency: 'ARS',
  minimumFractionDigits: 0
}).format(producto.precio_venta)

const productUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://peluquita-costura.luciano-zapata314.workers.dev').toString()
const productImage = imagenesSorted[0]?.url
const productImageAlt = imagenesSorted[0]?.alt || `${producto.nombre} de Peluquita Costuras`
const productDescription = `${producto.nombre} hecho a medida por Peluquita Costuras. Consultá disponibilidad, precio y encargos personalizados.`
const productImages = imagenesSorted.map((imagen) => imagen.url)
const productJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: producto.nombre,
    ...(productImages.length > 0 ? { image: productImages } : {}),
    description: productDescription,
    category: 'Confecciones artesanales',
    brand: {
      '@type': 'Brand',
      name: 'Peluquita Costuras'
    },
    offers: {
      '@type': 'Offer',
      price: producto.precio_venta,
      priceCurrency: 'ARS',
      availability: producto.stock > 0 ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
      itemCondition: 'https://schema.org/NewCondition',
      seller: {
        '@id': new URL('/#negocio', Astro.site ?? 'https://peluquita-costura.luciano-zapata314.workers.dev').toString()
      },
      url: productUrl
    }
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Inicio',
        item: new URL('/', Astro.site ?? 'https://peluquita-costura.luciano-zapata314.workers.dev').toString()
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Catálogo',
        item: new URL('/productos', Astro.site ?? 'https://peluquita-costura.luciano-zapata314.workers.dev').toString()
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: producto.nombre,
        item: productUrl
      }
    ]
  }
]
---

<Base
  title={`${producto.nombre} | Peluquita Costuras`}
  description={`${productDescription} Precio: ${precioFormateado}.`}
  image={productImage}
  imageAlt={productImage ? productImageAlt : undefined}
  ogType="product"
  jsonLd={productJsonLd}
>
  <!-- Breadcrumb -->
  <nav class="border-b border-[var(--color-outline-variant)]/40 bg-[var(--color-secondary-container)]/20 pt-20">
    <div class="mx-auto max-w-7xl px-6 py-5 sm:px-8">
      <ol class="font-label flex items-center gap-2 text-sm uppercase tracking-[0.16em]">
        <li>
          <a href="/" class="text-[var(--color-on-surface-variant)] transition-colors hover:text-[var(--color-primary)]">
            Inicio
          </a>
        </li>
        <li class="text-[var(--color-outline-variant)]">/</li>
        <li>
          <a href="/productos" class="text-[var(--color-on-surface-variant)] transition-colors hover:text-[var(--color-primary)]">
            Catálogo
          </a>
        </li>
        <li class="text-[var(--color-outline-variant)]">/</li>
        <li class="truncate font-bold text-[var(--color-primary)]">
          {producto.nombre}
        </li>
      </ol>
    </div>
  </nav>

  <!-- Detalle del producto -->
  <section class="bg-[var(--color-background)] px-6 py-16 sm:px-8 lg:py-24">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 gap-14 lg:grid-cols-2 lg:gap-16">
        <!-- Galería de imágenes -->
        <div>
          <ProductGallery images={imagenesSorted} productName={producto.nombre} productId={producto.id} />
        </div>

        <!-- Información del producto -->
        <div class="lg:pt-8">
          <span class="font-label mb-4 block text-xs font-bold uppercase tracking-[0.24em] text-[var(--color-secondary)]">
            Confección artesanal
          </span>

          <h1 class="font-headline mb-5 text-4xl leading-tight text-[var(--color-primary)] sm:text-5xl">
            <span transition:name={`producto-${producto.id}-titulo`}>{producto.nombre}</span>
          </h1>

          <p class="font-body mb-6 text-3xl font-bold text-[var(--color-secondary)]" transition:name={`producto-${producto.id}-precio`}>
            {precioFormateado}
          </p>

          {producto.stock > 0 ? (
            <div class="mb-6">
              <span class="font-label inline-flex items-center rounded-full bg-[var(--color-secondary-container)]/55 px-4 py-2 text-sm font-bold uppercase tracking-wider text-[var(--color-primary)]">
                <svg class="mr-2 h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                Disponible ({producto.stock} {producto.stock === 1 ? 'unidad' : 'unidades'})
              </span>
            </div>
          ) : (
            <div class="mb-6">
              <span class="font-label inline-flex items-center rounded-full bg-[var(--color-surface-container-high)] px-4 py-2 text-sm font-bold uppercase tracking-wider text-[var(--color-on-surface-variant)]">
                Sin stock
              </span>
            </div>
          )}

          <div class="mb-10 border-y border-[var(--color-outline-variant)]/40 py-8">
            <p class="font-body text-lg leading-relaxed text-[var(--color-on-surface-variant)]">
              Esta confección es única y hecha a medida con materiales de primera calidad.
              Cada pieza refleja nuestro compromiso con la excelencia y el diseño personalizado.
            </p>
            <div class="mt-8 grid grid-cols-2 gap-6">
              <div>
                <p class="font-headline text-2xl text-[var(--color-primary)]">100%</p>
                <p class="font-label text-xs uppercase tracking-tight text-[var(--color-on-surface-variant)]">Hecho a mano</p>
              </div>
              <div>
                <p class="font-headline text-2xl text-[var(--color-primary)]">A medida</p>
                <p class="font-label text-xs uppercase tracking-tight text-[var(--color-on-surface-variant)]">Consulta personalizada</p>
              </div>
            </div>
          </div>

          <!-- Formulario de consulta -->
          <div>
            <h2 class="font-headline mb-4 text-3xl text-[var(--color-primary)]">
              Consultar sobre este producto
            </h2>
            <p class="font-body mb-6 text-[var(--color-on-surface-variant)]">
              ¿Tenés alguna duda o querés hacer un encargo? Dejanos tu consulta y te respondemos a la brevedad.
            </p>
            <ContactForm productId={producto.id} productName={producto.nombre} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Volver al catálogo -->
  <section class="bg-[var(--color-secondary-container)]/25 px-6 py-10 sm:px-8">
    <div class="mx-auto max-w-7xl text-center">
      <a
        href="/productos"
        class="font-label inline-flex items-center rounded-full border border-[var(--color-primary)] px-8 py-3 text-sm font-bold uppercase tracking-widest text-[var(--color-primary)] transition-all hover:-translate-y-1 hover:bg-[var(--color-primary)] hover:text-white hover:shadow-xl"
      >
        <svg class="mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Volver al catálogo
      </a>
    </div>
  </section>
</Base>
