---
import '../styles/global.css'
import { ClientRouter } from 'astro:transitions'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'

interface Props {
  title: string
  description?: string
  image?: string
  imageAlt?: string
  ogType?: 'website' | 'product'
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]
}

const defaultImage = '/logo.png'

const {
  title,
  description = 'Costura artesanal hecha a medida en Paraná, Entre Ríos. Prendas, accesorios textiles y confecciones personalizadas con dedicación y calidad.',
  image = defaultImage,
  imageAlt = 'Logo de Peluquita Costuras',
  ogType = 'website',
  jsonLd = []
} = Astro.props

const siteUrl = Astro.site ?? new URL('https://peluquita-costura.luciano-zapata314.workers.dev')
const instagramUrl = 'https://www.instagram.com/franolilu_creaciones?igsh=MThxM3kwdDlwcTd3bw=='
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString()
const imageUrl = new URL(image, siteUrl).toString()
const isDefaultImage = image === defaultImage
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    '@id': new URL('/#negocio', siteUrl).toString(),
    name: 'Peluquita Costuras',
    url: siteUrl.toString(),
    logo: new URL('/logo.png', siteUrl).toString(),
    image: imageUrl,
    description,
    email: 'contacto@peluquitacosturas.com',
    telephone: '+54 9 11 1234-5678',
    sameAs: [instagramUrl],
    priceRange: '$$',
    areaServed: {
      '@type': 'AdministrativeArea',
      name: 'Paraná, Entre Ríos, Argentina'
    },
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Paraná',
      addressRegion: 'Entre Ríos',
      addressCountry: 'AR'
    },
    openingHoursSpecification: [
      {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
        opens: '09:00',
        closes: '18:00'
      },
      {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: 'Saturday',
        opens: '10:00',
        closes: '14:00'
      }
    ]
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': new URL('/#website', siteUrl).toString(),
    name: 'Peluquita Costuras',
    url: siteUrl.toString(),
    image: new URL('/logo.png', siteUrl).toString(),
    inLanguage: 'es-AR',
    publisher: {
      '@id': new URL('/#negocio', siteUrl).toString()
    }
  },
  ...(Array.isArray(jsonLd) ? jsonLd : [jsonLd])
].filter(Boolean)
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="author" content="Peluquita Costuras" />
    <meta name="theme-color" content="#8b4557" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="es-AR" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Libre+Caslon+Text:wght@400;700&display=swap" rel="stylesheet">
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content="Peluquita Costuras" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content={imageAlt} />
    {isDefaultImage && <meta property="og:image:type" content="image/png" />}
    {isDefaultImage && <meta property="og:image:width" content="1024" />}
    {isDefaultImage && <meta property="og:image:height" content="1024" />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body class="flex flex-col min-h-screen">
    <div id="page-loading" class="page-loading" role="status" aria-live="polite" aria-hidden="true" hidden transition:persist>
      <span class="page-loading__spinner" aria-hidden="true"></span>
      <span>Cargando...</span>
    </div>
    <Navbar />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
    <script>
      const getLoadingIndicator = () => document.getElementById('page-loading')

      const showLoadingIndicator = () => {
        const loadingIndicator = getLoadingIndicator()

        if (!loadingIndicator) return

        loadingIndicator.hidden = false
        loadingIndicator.setAttribute('aria-hidden', 'false')
        requestAnimationFrame(() => {
          loadingIndicator.classList.add('is-visible')
        })
      }

      const hideLoadingIndicator = () => {
        const loadingIndicator = getLoadingIndicator()

        if (!loadingIndicator) return

        loadingIndicator.classList.remove('is-visible')
        loadingIndicator.setAttribute('aria-hidden', 'true')
        window.setTimeout(() => {
          loadingIndicator.hidden = true
        }, 180)
      }

      document.addEventListener('astro:before-preparation', () => {
        showLoadingIndicator()
      })

      document.addEventListener('astro:after-preparation', () => {
        hideLoadingIndicator()
      })

      document.addEventListener('astro:after-swap', () => {
        hideLoadingIndicator()
      })

      document.addEventListener('astro:page-load', () => {
        hideLoadingIndicator()
      })
    </script>
  </body>
</html>

<style is:global>
  body {
    font-family: 'Inter', sans-serif;
  }
  
  h1, h2, h3, h4, h5, h6 {
    font-family: 'Libre Caslon Text', serif;
  }

  .page-loading {
    position: fixed;
    top: 1rem;
    left: 50%;
    z-index: 1000;
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.625rem 0.875rem;
    border: 1px solid rgba(139, 69, 87, 0.18);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.94);
    color: var(--color-primary);
    font-size: 0.875rem;
    font-weight: 600;
    box-shadow: 0 12px 30px rgba(31, 24, 28, 0.16);
    opacity: 0;
    pointer-events: none;
    transform: translate(-50%, -0.75rem);
    transition: opacity 160ms ease, transform 160ms ease;
  }

  .page-loading[hidden] {
    display: none;
  }

  .page-loading.is-visible {
    opacity: 1;
    transform: translate(-50%, 0);
  }

  .page-loading__spinner {
    width: 1rem;
    height: 1rem;
    border: 2px solid rgba(139, 69, 87, 0.22);
    border-top-color: var(--color-primary);
    border-radius: 999px;
    animation: page-loading-spin 700ms linear infinite;
  }

  @keyframes page-loading-spin {
    to {
      transform: rotate(360deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .page-loading,
    .page-loading__spinner {
      transition: none;
      animation: none;
    }
  }
</style>
