---
interface Props {
  productId?: number
  productName?: string
}

const { productId, productName } = Astro.props
---

<form class="space-y-4" id="contact-form">
  <div>
    <label for="nombre" class="block text-sm font-medium text-gray-700 mb-1">
      Nombre completo *
    </label>
    <input
      type="text"
      id="nombre"
      name="nombre"
      required
      class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-[var(--color-primary)] focus:border-transparent"
    />
  </div>

  <div>
    <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
      Email *
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-[var(--color-primary)] focus:border-transparent"
    />
  </div>

  <div>
    <label for="telefono" class="block text-sm font-medium text-gray-700 mb-1">
      Teléfono (opcional)
    </label>
    <input
      type="tel"
      id="telefono"
      name="telefono"
      class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-[var(--color-primary)] focus:border-transparent"
    />
  </div>

  <div>
    <label for="mensaje" class="block text-sm font-medium text-gray-700 mb-1">
      Mensaje *
    </label>
    <textarea
      id="mensaje"
      name="mensaje"
      rows="4"
      required
      placeholder={productName ? `Hola, me interesa ${productName}...` : 'Escribe tu consulta aquí...'}
      class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-[var(--color-primary)] focus:border-transparent"
    ></textarea>
  </div>

  <input type="hidden" name="producto_id" value={productId || ''} />

  <div id="message-container" class="hidden">
    <p id="message-text" class="text-sm"></p>
  </div>

  <button
    type="submit"
    class="w-full px-6 py-3 bg-[var(--color-primary)] text-white font-medium rounded-md hover:bg-[var(--color-primary)]/90 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
    id="submit-btn"
  >
    Enviar Consulta
  </button>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const messageContainer = document.getElementById('message-container') as HTMLDivElement;
  const messageText = document.getElementById('message-text') as HTMLParagraphElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando...';
    
    const formData = new FormData(form);
    const data = {
      nombre: formData.get('nombre'),
      email: formData.get('email'),
      telefono: formData.get('telefono') || null,
      mensaje: formData.get('mensaje'),
      producto_id: formData.get('producto_id') ? parseInt(formData.get('producto_id') as string) : null
    };

    try {
      const response = await fetch('/api/consulta', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(data),
      });

      const result = await response.json();

      if (response.ok) {
        messageContainer.classList.remove('hidden');
        messageText.textContent = '¡Consulta enviada con éxito! Te responderemos pronto.';
        messageText.className = 'text-sm text-green-600';
        form.reset();
      } else {
        throw new Error(result.error || 'Error al enviar la consulta');
      }
    } catch (error) {
      messageContainer.classList.remove('hidden');
      messageText.textContent = error instanceof Error ? error.message : 'Error al enviar la consulta. Por favor, intenta nuevamente.';
      messageText.className = 'text-sm text-red-600';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Enviar Consulta';
    }
  });
</script>
