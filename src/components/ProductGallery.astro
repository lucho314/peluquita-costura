---
interface Image {
  url: string
  alt?: string | null
}

interface Props {
  images: Image[]
  productName: string
  productId: number
}

const { images, productName, productId } = Astro.props
const sortedImages = images
---

<div class="space-y-5">
  {sortedImages.length > 0 ? (
    <>
      <div class="relative">
        <div class="absolute -left-4 -top-4 hidden h-full w-full rounded-xl border border-[var(--color-secondary)]/30 sm:block"></div>
        <div class="relative aspect-[4/5] overflow-hidden rounded-xl bg-[var(--color-surface-container)] shadow-[0_24px_70px_rgba(31,27,19,0.14)]">
        <img
          id="main-image"
          src={sortedImages[0].url}
          alt={sortedImages[0].alt || productName}
          transition:name={`producto-${productId}-imagen`}
          width="800"
          height="800"
          sizes="(min-width: 1024px) 50vw, 100vw"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          class="h-full w-full object-cover"
        />
        </div>
      </div>
      
      {sortedImages.length > 1 && (
        <div class="grid grid-cols-4 gap-3 sm:gap-4">
          {sortedImages.map((image, index) => (
            <button
              type="button"
              data-image={image.url}
              data-alt={image.alt || `${productName} - imagen ${index + 1}`}
              aria-label={`Ver imagen ${index + 1} de ${productName}`}
              class="thumbnail aspect-square overflow-hidden rounded-lg bg-[var(--color-surface-container)] ring-1 ring-[var(--color-outline-variant)]/60 transition-all hover:-translate-y-1 hover:ring-2 hover:ring-[var(--color-primary)]"
            >
              <img
                src={image.url}
                alt={image.alt || `${productName} - imagen ${index + 1}`}
                width="200"
                height="200"
                sizes="(min-width: 1024px) 12vw, 25vw"
                class="h-full w-full object-cover"
                loading="lazy"
                decoding="async"
              />
            </button>
          ))}
        </div>
      )}
    </>
  ) : (
    <div class="flex aspect-[4/5] items-center justify-center rounded-xl bg-[var(--color-surface-container)] ring-1 ring-[var(--color-outline-variant)]/60">
      <p class="font-label text-sm uppercase tracking-widest text-[var(--color-on-surface-variant)]">Sin imágenes disponibles</p>
    </div>
  )}
</div>

<script>
  const setupProductGallery = () => {
    const mainImage = document.getElementById('main-image') as HTMLImageElement | null
    const thumbnails = document.querySelectorAll<HTMLButtonElement>('.thumbnail')

    thumbnails.forEach((thumbnail) => {
      if (thumbnail.dataset.galleryReady === 'true') return

      thumbnail.dataset.galleryReady = 'true'
      thumbnail.addEventListener('click', () => {
        const imageUrl = thumbnail.dataset.image
        const imageAlt = thumbnail.dataset.alt

        if (!imageUrl || !mainImage) return

        mainImage.src = imageUrl
        if (imageAlt) mainImage.alt = imageAlt
      })
    })
  }

  setupProductGallery()
  document.addEventListener('astro:page-load', setupProductGallery)
</script>
