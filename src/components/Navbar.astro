---
const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/productos', label: 'Catálogo' },
  { href: '/contacto', label: 'Contacto' }
]

const currentPath = Astro.url.pathname
---

<nav class="fixed top-0 z-50 w-full bg-[var(--color-background)]/95 shadow-sm backdrop-blur-md transition-all duration-300 md:bg-[var(--color-background)]/80">
  <div class="mx-auto max-w-7xl px-6 sm:px-8">
    <div class="flex h-24 items-center justify-between md:h-20">
      <div class="flex-shrink-0">
        <a href="/" class="group flex flex-col text-[var(--color-primary)] transition-opacity hover:opacity-80">
          <span class="font-script text-4xl leading-none md:text-4xl">Peluquita Costura</span>
          <span class="font-label mt-2 block text-center text-xs font-bold uppercase tracking-[0.32em] text-[var(--color-secondary)] md:hidden">
            - Taller Artesanal -
          </span>
        </a>
      </div>
      
      <div class="hidden md:block">
        <div class="ml-10 flex items-center gap-10">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                'font-headline pb-1 text-lg tracking-tight transition-colors',
                currentPath === link.href
                  ? 'border-b-2 border-[var(--color-secondary-container)] font-bold text-[var(--color-primary)]'
                  : 'text-stone-600 hover:text-[var(--color-primary)]'
              ]}
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>

      <div class="hidden items-center gap-6 text-[var(--color-primary)] md:flex" aria-hidden="true">
        <span class="text-xl">✂</span>
        <span class="h-8 w-px bg-[var(--color-outline-variant)]"></span>
        <span class="font-label text-xs uppercase tracking-[0.24em]">Atelier</span>
      </div>

      <!-- Mobile menu button -->
      <div class="flex items-center gap-5 md:hidden">
        <a href="/productos" class="text-[var(--color-primary)]" aria-label="Ver catálogo">
          <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 8.25h10.5l.75 12h-12l.75-12Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 8.25a3 3 0 0 1 6 0" />
          </svg>
        </a>
        <button
          type="button"
          class="inline-flex items-center justify-center text-[var(--color-primary)] hover:bg-[var(--color-secondary-container)]/30 focus:outline-none"
          aria-label="Toggle menu"
          id="mobile-menu-button"
        >
          <svg class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="hidden border-t border-[var(--color-outline-variant)] bg-[var(--color-background)]/95 md:hidden" id="mobile-menu">
    <div class="space-y-1 px-4 pb-5 pt-2">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="font-headline block px-3 py-2 text-base text-stone-700 hover:text-[var(--color-primary)]"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  
  button?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
