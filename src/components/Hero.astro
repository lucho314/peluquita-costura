---
interface Props {
  title: string
  subtitle: string
  ctaText?: string
  ctaHref?: string
}

const { title, subtitle, ctaText = 'Ver Catálogo', ctaHref = '/productos' } = Astro.props
---

<section class="relative bg-gradient-to-br from-[var(--color-secondary)] to-[var(--color-tertiary)] py-24 lg:py-32">
  <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1558769132-cb1aea28c0d1?w=1600')] bg-cover bg-center opacity-20"></div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-serif font-bold text-white mb-6 drop-shadow-lg">
      {title}
    </h1>
    
    <p class="text-xl sm:text-2xl text-white/90 mb-8 max-w-3xl mx-auto drop-shadow">
      {subtitle}
    </p>
    
    {ctaText && ctaHref && (
      <a
        href={ctaHref}
        class="inline-flex items-center px-8 py-3 border border-transparent text-base font-medium rounded-md text-white bg-[var(--color-primary)] hover:bg-[var(--color-primary)]/90 transition-colors shadow-lg hover:shadow-xl"
      >
        {ctaText}
        <svg class="ml-2 -mr-1 w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </a>
    )}
  </div>
</section>
