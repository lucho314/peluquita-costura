---
interface Props {
  id: number
  nombre: string
  precio: number
  imagen?: string
  stock: number
}

const { id, nombre, precio, imagen, stock } = Astro.props

const imagenUrl = imagen || 'https://placehold.co/600x800/f6edde/6f2e40?text=Sin+Imagen'
const precioFormateado = new Intl.NumberFormat('es-AR', {
  style: 'currency',
  currency: 'ARS',
  minimumFractionDigits: 0
}).format(precio)
---

<article class="group flex flex-col gap-6">
  <a href={`/productos/${id}`} class="block">
    <div class="aspect-[3/4] overflow-hidden rounded-xl bg-[var(--color-surface-container)] shadow-sm transition-transform duration-500 group-hover:-translate-y-2">
      <img
        src={imagenUrl}
        alt={nombre}
        transition:name={`producto-${id}-imagen`}
        width="400"
        height="400"
        sizes="(min-width: 1024px) 25vw, (min-width: 640px) 50vw, 100vw"
        loading="lazy"
        decoding="async"
        class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
      />
    </div>
    
    <div class="pt-6">
      <h3 class="font-headline mb-1 line-clamp-2 text-xl text-[var(--color-primary)]">
        <span transition:name={`producto-${id}-titulo`}>{nombre}</span>
      </h3>
      
      <div class="flex items-center justify-between gap-4">
        <span class="font-label text-sm uppercase tracking-widest text-[var(--color-on-surface-variant)]">
          {stock > 0 ? 'Disponible' : 'Sin stock'}
        </span>
        <p class="font-body font-bold text-[var(--color-secondary)]" transition:name={`producto-${id}-precio`}>
          {precioFormateado}
        </p>
      </div>
    </div>
  </a>
</article>
